# FastAPI
API_VERSION=v1
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 数据库 - Supabase PostgreSQL with pgvector
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# pgvector 配置
VECTOR_DIMENSIONS=768
VECTOR_SIMILARITY_METRIC=cosine

# LLM 配置（支持豆包/通义千问）
LLM_PROVIDER=doubao  # 可选: doubao, qwen
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=doubao-pro  # 豆包模型名
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# JWT 认证
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传
MAX_UPLOAD_SIZE=52428800  # 50MB
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,docx,txt,md

# 日志
LOG_LEVEL=INFO
