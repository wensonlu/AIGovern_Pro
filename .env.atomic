# Atomic Configuration for AIGovern_Pro
# 这个文件配置Atomic CLI的行为

# 选择默认agent: claude, opencode, copilot
DEFAULT_AGENT=claude

# 选择默认模型
# 推荐: claude-sonnet-4.6 (快速) 或 claude-opus-4.6 (功能强大)
DEFAULT_MODEL=claude-opus-4.6

# 是否启用MCP servers
ENABLE_MCP=true

# 研究时使用的sub-agents数量
RESEARCH_AGENTS=5

# 自动提交前是否检查测试
CHECK_TESTS_BEFORE_COMMIT=true

# 项目类型
PROJECT_TYPE=fullstack
PROJECT_NAME=AIGovern_Pro
