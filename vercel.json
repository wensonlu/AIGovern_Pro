{
  "version": 2,
  "name": "ai-govern-pro",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/docs",
      "destination": "/api/docs"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/openapi.json"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "/api"
  }
}