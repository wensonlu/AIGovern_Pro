# ============================================
# AIGovern Pro - 环境变量配置模板
# 复制为 .env 文件并填入实际值
# ============================================

# ============================================
# Supabase 数据库配置（推荐）
# ============================================
# Supabase 项目 URL (格式: https://<project-id>.supabase.co)
SUPABASE_URL=https://jdfrubpfjwhbvxfdyzah.supabase.co

# Supabase 数据库连接 URL (PostgreSQL 连接字符串)
# 格式: postgresql://postgres:<password>@<host>:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.jdfrubpfjwhbvxfdyzah.supabase.co:5432/postgres

# Supabase 服务密钥（用于管理操作，如创建函数等）
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase 匿名密钥（用于前端客户端访问）
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpkZnJ1YnBmandoYnZ4ZmR5emFoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2MjUyMzEsImV4cCI6MjA4OTIwMTIzMX0.HOPdelKdyR-tTqmzkMAkYuJlZ6rEn83_e-vOHUmiMVg

# ============================================
# 后端配置
# ============================================
# FastAPI 密钥
SECRET_KEY=your-secret-key-here

# 后端 API 地址（Vercel 部署时使用）
# 开发环境: http://localhost:8000
# 生产环境: https://ai-govern-pro.vercel.app
API_BASE_URL=http://localhost:8000

# ============================================
# 前端配置
# ============================================
# Vite 环境变量（前端使用 VITE_ 前缀）
# 开发环境 API 地址
VITE_API_BASE_URL=http://localhost:8000

# 生产环境 API 地址（相对路径，同域部署）
# VITE_API_BASE_URL=/api

# ============================================
# AI 模型配置
# ============================================
# 豆包/火山方舟 API Key
DOUBAO_API_KEY=your-doubao-api-key

# 通义千问 API Key（备用）
DASHSCOPE_API_KEY=your-dashscope-api-key

# OpenAI API Key（可选）
OPENAI_API_KEY=your-openai-api-key

# ============================================
# 向量数据库配置（使用 Supabase pgvector）
# ============================================
# pgvector 已内置在 Supabase 中，无需额外配置
# 向量维度（根据 embedding 模型设置，默认 1024）
VECTOR_DIMENSION=1024

# ============================================
# Redis 缓存配置（可选）
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# 邮件服务配置（可选，用于通知功能）
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
